---
import { Github, Linkedin } from 'lucide-vue-next';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <body>
      <div class="container mx-auto px-4 pt-5">
        <div class="flex justify-between items-center mb-20">
          <div class="flex gap-30">
            <a class="font-mono text-lg lg:text-xl" href="/">{title}</a>

            <!-- Navbar -->
            <ul class="flex gap-5">
              <li>
                <a
                  class="font-mono text-xl underline underline-offset-6 decoration-3"
                  href="#home">me</a
                >
              </li>
              <li>
                <a
                  class="font-mono text-xl underline underline-offset-6 decoration-3"
                  href="/uses">uses</a
                >
              </li>
              <li>
                <a
                  class="font-mono text-xl underline underline-offset-6 decoration-3"
                  href="#home">blog</a
                >
              </li>
            </ul>
          </div>

          <div class="flex gap-5">
            <a href="https://github.com/alfrendo-silalahi" target="_blank"
              ><Github /></a
            >
            <a
              href="https://www.linkedin.com/in/alfrendo-silalahi/"
              target="_blank"><Linkedin /></a
            >
          </div>
        </div>

        <!-- Main Content -->
        <slot />
      </div>
    </body>
  </body>
</html>
